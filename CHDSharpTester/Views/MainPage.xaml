<UserControl x:Class="CHDSharpTester.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:CHDSharpTester.ViewModels"
      xmlns:m="clr-namespace:CHDSharpTester.Models"
      xmlns:views="clr-namespace:CHDSharpTester.Views"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=vm:MainViewModel}" x:ClassModifier="internal">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <views:StatusIconConverter x:Key="StatusIconConverter" />

        <DataTemplate x:Key="SubTestTemplate" DataType="{x:Type m:SubTestResult}">
            <Border Padding="8,4" Margin="0,1"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Width="24" TextAlignment="Center"
                               FontFamily="Segoe UI Symbol" FontSize="14"
                               Text="{Binding Status, Converter={StaticResource StatusIconConverter}}" />
                    <TextBlock Grid.Column="1" Text="{Binding TestName}"
                               VerticalAlignment="Center" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2" Text="{Binding Detail}"
                               VerticalAlignment="Center" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="11" Margin="8,0,0,0" />
                    <TextBlock Grid.Column="3" Text="{Binding ElapsedSeconds, StringFormat={}{0:N2}s}"
                               VerticalAlignment="Center" HorizontalAlignment="Right"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="11" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,10,20,20">

            <!-- HEADER -->
            <TextBlock Text="CHDSharp Tester" FontSize="22" FontWeight="Bold"
                       Margin="0,0,0,16"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

            <!-- ========================================================== -->
            <!-- SECTION 1: CONFIGURATION -->
            <!-- ========================================================== -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Configuration" FontSize="14" FontWeight="Bold"
                               Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="chdman.exe:" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <TextBox Grid.Column="1" Text="{Binding ChdmanPath, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True" VerticalAlignment="Center"
                                 Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:Button Grid.Column="2" Content="Browse" Margin="8,0,0,0"
                                   Command="{Binding BrowseChdmanCommand}" Appearance="Primary" />
                    </Grid>

                    <TextBlock Margin="0,0,0,10" FontSize="11" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="No chdman.exe selected. Tests requiring chdman will be skipped." />
                                <Setter Property="Foreground" Value="#FF9800" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChdmanValid}" Value="True">
                                        <Setter Property="Text" Value="chdman.exe ready." />
                                        <Setter Property="Foreground" Value="#4CAF50" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:Button Content="Add Files" Command="{Binding AddFilesCommand}"
                                   Appearance="Primary" Margin="0,0,8,0" />
                        <ui:Button Content="Add Folder" Command="{Binding AddFolderCommand}"
                                   Appearance="Secondary" />
                        <TextBlock Text="{Binding FilesSummary}" VerticalAlignment="Center"
                                   Margin="16,0,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <Border Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                            CornerRadius="6" Padding="4" MinHeight="80">
                        <ItemsControl ItemsSource="{Binding Files}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:ChdFileEntry}">
                                    <Border Padding="6,4" Margin="2"
                                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="{Binding FileSize}"
                                                       VerticalAlignment="Center" Margin="12,0,0,0" FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <ui:Button Grid.Column="2" Content="Remove" Margin="8,0,0,0"
Command="{Binding DataContext.RemoveFileCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding}" Appearance="Danger"
                                                       FontSize="11" Padding="8,2" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <ui:Button Content="Run All Tests" Margin="0,12,0,0"
                               Command="{Binding RunTestsCommand}"
                               IsEnabled="{Binding CanRunTests}"
                               Appearance="Primary" FontSize="14"
                               HorizontalAlignment="Center" MinWidth="180"
                               Height="40" />
                </StackPanel>
            </Border>

            <!-- ========================================================== -->
            <!-- SECTION 2: PROGRESS -->
            <!-- ========================================================== -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,12"
                    Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Progress" FontSize="14" FontWeight="Bold"
                               Margin="0,0,0,10" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar Value="{Binding ProgressValue}" Height="20"
                                     Minimum="0" Maximum="100" />
                        <TextBlock Grid.Column="1" Text="{Binding FileProgress}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   FontWeight="SemiBold" />
                    </Grid>
                    <TextBlock Text="{Binding ProgressText}" TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{Binding CurrentTest}" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                    <Border Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                            CornerRadius="6" Padding="8" Margin="0,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <ui:Button Grid.Row="0" Content="Copy Log" FontSize="10"
                                       Margin="0,0,0,4" Padding="6,2"
                                       HorizontalAlignment="Right"
                                       Command="{Binding CopyLogCommand}" />
                            <TextBox Grid.Row="1" Text="{Binding LogText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontFamily="Consolas" FontSize="11"
                                 Foreground="{DynamicResource TextFillColorSecondaryBrush}"
VerticalScrollBarVisibility="Visible"
                                  HorizontalScrollBarVisibility="Auto"
                                  TextWrapping="NoWrap"
                                  MinHeight="100"
                                  MaxHeight="160"
                                 TextChanged="LogTextBox_OnTextChanged" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ========================================================== -->
            <!-- SECTION 3: RESULTS -->
            <!-- ========================================================== -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,12"
                    Visibility="{Binding ShowResults, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Results" FontSize="14" FontWeight="Bold"
                               Margin="0,0,0,10" />

                    <!-- summary cards -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#1B5E20" CornerRadius="8"
                                Padding="14,8" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="PASSED" Foreground="#A5D6A7" FontSize="11" />
                                <TextBlock Text="{Binding SummaryPassed}" Foreground="White"
                                           FontSize="26" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#B71C1C" CornerRadius="8"
                                Padding="14,8" Margin="3,0">
                            <StackPanel>
                                <TextBlock Text="FAILED" Foreground="#EF9A9A" FontSize="11" />
                                <TextBlock Text="{Binding SummaryFailed}" Foreground="White"
                                           FontSize="26" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#E65100" CornerRadius="8"
                                Padding="14,8" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="SKIPPED" Foreground="#FFCC80" FontSize="11" />
                                <TextBlock Text="{Binding SummarySkipped}" Foreground="White"
                                           FontSize="26" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Text="{Binding SummaryText}" FontWeight="SemiBold"
                               Margin="0,0,0,4" FontSize="12" />
                    <TextBlock Text="{Binding SummarySubText}" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <ui:Button Content="Export to PDF" Command="{Binding ExportPdfCommand}"
                                   Appearance="Primary" Margin="0,0,8,0" />
                        <ui:Button Content="Copy Results" Command="{Binding CopyResultsCommand}"
                                   Appearance="Secondary" />
                    </StackPanel>

                    <!-- per-file results -->
                    <Border Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                            CornerRadius="6" Padding="4">
                        <ListBox ItemsSource="{Binding FileResults}" BorderThickness="0"
                                 Background="Transparent" MaxHeight="400">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:PerFileResult}">
                                    <Border Margin="2" Padding="0"
                                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            CornerRadius="4">
                                        <Expander>
                                            <Expander.Header>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="90" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Width="28" TextAlignment="Center"
                                                               FontFamily="Segoe UI Symbol" FontSize="16">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="✓" />
                                                                <Setter Property="Foreground" Value="#4CAF50" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AllPassed}" Value="False">
                                                                        <Setter Property="Text" Value="✗" />
                                                                        <Setter Property="Foreground" Value="#F44336" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="1" Text="{Binding FileName}"
                                                               FontWeight="SemiBold" VerticalAlignment="Center"
                                                               Margin="4,0,0,0" />
                                                    <TextBlock Grid.Column="2" Text="{Binding FileSize}"
                                                               VerticalAlignment="Center" FontSize="11"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Margin="12,0,0,0" />
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                                HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock Foreground="#4CAF50" FontWeight="Bold">
                                                            <TextBlock.Text>
                                                                <Binding Path="Passed" StringFormat="{}{0} P"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBlock Foreground="#F44336" FontWeight="Bold">
                                                            <TextBlock.Text>
                                                                <Binding Path="Failed" StringFormat="  {0} F"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBlock Foreground="#FF9800" FontWeight="Bold">
                                                            <TextBlock.Text>
                                                                <Binding Path="Skipped" StringFormat="  {0} S"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Expander.Header>
                                            <StackPanel Margin="16,4,4,8">
                                                <TextBlock Text="{Binding ElapsedSeconds, StringFormat='Total: {0:N2}s'}"
                                                           FontSize="11" Margin="0,0,0,6"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                                <ItemsControl ItemsSource="{Binding SubTests}"
                                                              ItemTemplate="{StaticResource SubTestTemplate}" />
                                            </StackPanel>
                                        </Expander>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                Padding="10,5">
            <Border BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                    Padding="0">
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12" />
                <ProgressBar Grid.Column="2"
                             IsIndeterminate="{Binding IsRunning}"
                             Width="80" Height="10"
                             Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                             Margin="12,0,0,0" />
            </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
