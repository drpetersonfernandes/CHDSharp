<Window x:Class="CHDSharpTester.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="About CHDSharp Tester"
        Width="600" Height="550"
        MinWidth="400" MinHeight="380"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource ApplicationBackgroundBrush}" x:ClassModifier="internal">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title & Version -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Source="pack://application:,,,/Images/logo.png"
                       Width="140" Height="140" Margin="0,0,16,0" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="CHDSharp Tester" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock x:Name="AppVersionTextBlock" FontSize="13" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Description & Links -->
        <StackPanel Grid.Row="1">
            <TextBlock x:Name="DescriptionTextBlock" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,12" />

            <TextBlock Text="Links" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,6" />
            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                <Hyperlink x:Name="GitHubLink" RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="{DynamicResource AccentFillColorDefaultBrush}">
                    GitHub Repository
                </Hyperlink>
            </TextBlock>
            <TextBlock FontSize="12" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                <Hyperlink x:Name="WebLink" RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="{DynamicResource AccentFillColorDefaultBrush}">
                    www.PureLogicCode.com
                </Hyperlink>
            </TextBlock>

            <!-- Acknowledgements -->
            <TextBlock Text="Acknowledgements" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,16,0,6" />
            <TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                Built with <Hyperlink NavigateUri="https://github.com/nicoco007/WPF-UI" RequestNavigate="Hyperlink_RequestNavigate"
                                      Foreground="{DynamicResource AccentFillColorDefaultBrush}">
                    WPF-UI</Hyperlink> for the Fluent Design interface.
            </TextBlock>
            <TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                Uses <Hyperlink NavigateUri="https://www.nuget.org/packages/Serilog" RequestNavigate="Hyperlink_RequestNavigate"
                                Foreground="{DynamicResource AccentFillColorDefaultBrush}">
                    Serilog</Hyperlink> for structured logging.
            </TextBlock>
            <TextBlock FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                Uses <Hyperlink NavigateUri="https://www.nuget.org/packages/QuestPDF" RequestNavigate="Hyperlink_RequestNavigate"
                                Foreground="{DynamicResource AccentFillColorDefaultBrush}">
                    QuestPDF</Hyperlink> for PDF report export.
            </TextBlock>
            <TextBlock FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                Cross-validates against <Hyperlink NavigateUri="https://www.mamedev.org/" RequestNavigate="Hyperlink_RequestNavigate"
                                                    Foreground="{DynamicResource AccentFillColorDefaultBrush}">
                    MAME chdman</Hyperlink> for verification.
            </TextBlock>
        </StackPanel>

        <!-- Close Button -->
        <ui:Button Grid.Row="2" Content="Close" Click="CloseButton_Click"
                   Appearance="Primary" HorizontalAlignment="Right"
                   Margin="0,16,0,0" Width="80" />
    </Grid>
</Window>
